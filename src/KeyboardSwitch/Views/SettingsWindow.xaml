<Window x:Class="KeyboardSwitch.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="KeyboardSwitch — настройки"
        Height="560" Width="520"
        MinHeight="480" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        Background="#FAFAFA"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinWidth" Value="80"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12">
            <Button Content="Скрыть в трей" Click="OnHide" Margin="0,0,8,0"/>
            <Button Content="Выйти" Click="OnExit"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
            <StackPanel>

                <GroupBox Header="Общие">
                    <StackPanel>
                        <CheckBox Content="Включить мониторинг" IsChecked="{Binding Enabled, Mode=TwoWay}"/>
                        <CheckBox Content="Подавать звуковой сигнал при неверной раскладке"
                                  IsChecked="{Binding PlaySound, Mode=TwoWay}"/>
                        <CheckBox Content="Авто-исправлять слово (экспериментально)"
                                  IsChecked="{Binding AutoSwitchOn, Mode=TwoWay}"
                                  ToolTip="Стирает набранное слово и печатает заново в правильной раскладке. Может не работать в играх и окнах с повышенными правами."/>
                        <CheckBox Content="Запускать при старте Windows"
                                  IsChecked="{Binding AutoStartOn, Mode=TwoWay}"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Звук">
                    <StackPanel>
                        <TextBlock Text="Файл сигнала (WAV). Если не указан — используется встроенный/системный."
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Обзор…" Click="OnBrowseSound" Margin="6,0,0,0"/>
                            <Button DockPanel.Dock="Right" Content="Тест" Click="OnTestSound" Margin="6,0,0,0"/>
                            <TextBox Text="{Binding CustomSoundPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Эвристика">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Чувствительность:" VerticalAlignment="Center" Width="160"/>
                            <ComboBox ItemsSource="{Binding SensitivityOptions}"
                                      SelectedItem="{Binding Sensitivity, Mode=TwoWay}"
                                      Width="160" HorizontalAlignment="Left"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Минимальная длина слова:" VerticalAlignment="Center" Width="160"/>
                            <TextBox Text="{Binding MinWordLength, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Width="60" HorizontalAlignment="Left"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Не отслеживать в процессах (имена .exe)">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <Button DockPanel.Dock="Right" Content="Добавить" Click="OnAddIgnored" Margin="6,0,0,0"/>
                            <TextBox Text="{Binding NewIgnoredProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="OnIgnoredKeyDown"/>
                        </DockPanel>
                        <ListBox ItemsSource="{Binding IgnoredProcesses}" Height="110">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Удалить"
                                                Click="OnRemoveIgnored" Tag="{Binding}"
                                                Padding="6,2" MinWidth="60"/>
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </GroupBox>

                <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="11">
                    <Run Text="Поддерживаются раскладки RU ↔ EN. Окна с повышенными правами (UAC) не отслеживаются — это ограничение Windows."/>
                </TextBlock>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
